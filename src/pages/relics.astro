---
import '/src/styles/basico.css';

// Las importaciones de componentes déjalas igual, esas están bien:
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelicsApp from '../components/Relics/RelicsApp.jsx';
import { getDatosRelics } from "../lib/relics.js";
import { getVersionActual } from "../lib/listapj.js";

export const prerender = false;
const relics = await getDatosRelics();
const versionActual = await getVersionActual();
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relics - HSR Wiki</title>
</head>
<!-- Cloudflare Web Analytics -->
 <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "fcc1cfa50eb54cd6b251acfc91e1f9bb"}'>
</script>
<!-- End Cloudflare Web Analytics -->
<body>
    <Nav />
    <main id="main-scroll">
        <div id="content-layout">
            <h2 class="section-title">RELICS</h2>

            <RelicsApp 
                relicsIniciales={relics} 
                versionActual={versionActual} 
                client:load 
            />
    <Footer />
    </main>
</body>
</html>