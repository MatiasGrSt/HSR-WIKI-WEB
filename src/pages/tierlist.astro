---
import "/src/styles/basico.css";
import "/src/styles/tierlist.css";

import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import TierListApp from "../components/TierList/TierListApp.jsx";

let personajes = [];
let tierData = [];

try {
    const [resPers, resTier] = await Promise.all([
        fetch("https://www.astralwiki.com/php/datos.php"),
        fetch("https://www.astralwiki.com/php/tier_list.php"),
    ]);
    personajes = await resPers.json();
    tierData = await resTier.json();
} catch (e) {
    console.error("Error cargando la tier list:", e);
}
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="description"
            content="Tier list actualizada de Honkai: Star Rail con valoraciones EV por rol y modo de juego."
        />
        <title>Tier List — Astral Wiki HSR</title>
    </head>
    <body>
        <Nav />
        <main id="main-scroll">
            <div id="content-layout">
                <h2 class="section-title">ASTRAL WIKI OFICIAL TIER LIST</h2>

                <div class="tl-disclaimer-grid">
                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Gear / Settings -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <circle cx="12" cy="12" r="3"></circle>
                                <path
                                    d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                                ></path>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>Assumed equipment</strong><br />
                            <em>5★</em> characters are evaluated with their <strong
                                >Light Cone</strong
                            > and <strong>E0</strong>. <em>4★</em> characters with <strong
                                >E6</strong
                            > and an accessible cone (craftable or Battle Pass).
                        </div>
                    </div>

                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Diamond / Relic -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <polygon points="12 2 22 9 18 21 6 21 2 9"
                                ></polygon>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>Relics</strong><br />
                            We assume <strong>optimal BiS</strong> relics with
                            ideal stats. A character with mediocre relics
                            can perform significantly below their EV.
                        </div>
                    </div>

                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Team / Users -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                                ></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>Team context</strong><br />
                            EV reflects performance in their <strong
                                >best possible team</strong
                            >. The same character may perform differently depending on
                            the available supports.
                        </div>
                    </div>

                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Hash / EV value -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="4" y1="9" x2="20" y2="9"></line>
                                <line x1="4" y1="15" x2="20" y2="15"></line>
                                <line x1="10" y1="3" x2="8" y2="21"></line>
                                <line x1="16" y1="3" x2="14" y2="21"></line>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>What is EV?</strong><br />
                            The <strong>EV (Evaluation Value)</strong> is a metric used in 
                            Astral Wiki, ranging from <em>0</em> (minimum) to <em
                                >5</em
                            > (maximum). It is not an official HoYoverse rating.
                        </div>
                    </div>

                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Refresh / Update -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <polyline points="23 4 23 10 17 10"></polyline>
                                <polyline points="1 20 1 14 7 14"></polyline>
                                <path
                                    d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"
                                ></path>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>Continuous updates</strong><br />
                            Values are reviewed with every <strong
                                >major patch</strong
                            >. Buffs, nerfs, or new characters can change
                            the meta quickly.
                        </div>
                    </div>

                    <div class="tl-info-box">
                        <span class="tl-info-icon">
                            <!-- Edit / Editorial -->
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M12 20h9"></path>
                                <path
                                    d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
                                ></path>
                            </svg>
                        </span>
                        <div class="tl-info-text">
                            <strong>Editorial opinion</strong><br />
                            This tier list reflects the <strong
                                >Astral Wiki team's evaluation</strong
                            >. It may differ from other community
                            tier lists.
                        </div>
                    </div>
                </div>

                <TierListApp
                    personajes={personajes}
                    tierListData={tierData}
                    client:only="react"
                />
            </div>

            <Footer />
        </main>
    </body>
</html>
